<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- iOS requires macOS + Xcode; add net10.0-ios back when building on a Mac CI agent -->
	  <TargetFrameworks>net10.0-android36.0</TargetFrameworks>
    <OutputType>Exe</OutputType>
    <RootNamespace>MealPlanner.UI.Mobile</RootNamespace>
    <UseMaui>true</UseMaui>
    <SingleProject>true</SingleProject>
    <ImplicitUsings>enable</ImplicitUsings>
    <NoWarn>MVVMTK0045</NoWarn>
    <Nullable>enable</Nullable>

    <ApplicationTitle>MealPlanner</ApplicationTitle>
    <ApplicationId>com.mealplanner.mobile</ApplicationId>
    <ApplicationVersion>1</ApplicationVersion>
    <ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>

    <SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'ios'">15.0</SupportedOSPlatformVersion>
    <SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'android'">24.0</SupportedOSPlatformVersion>
    <SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'windows'">10.0.19041.0</SupportedOSPlatformVersion>
    <TargetPlatformMinVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'windows'">10.0.19041.0</TargetPlatformMinVersion>
  </PropertyGroup>

  <ItemGroup>
    <MauiIcon Include="Resources\AppIcon\appicon.svg" ForegroundFile="Resources\AppIcon\appiconfg.svg" Color="#512BD4" />
    <MauiSplashScreen Include="Resources\Splash\splash.svg" Color="#512BD4" BaseSize="128,128" />
    <MauiImage Include="Resources\Images\*" />
    <MauiFont Include="Resources\Fonts\*" />
    <MauiAsset Include="Resources\Raw\**" LogicalName="%(RecursiveDir)%(Filename)%(Extension)" />
    <EmbeddedResource Include="appsettings.json" />
  </ItemGroup>

  <ItemGroup>
    <Compile Update="App.xaml.cs">
      <DependentUpon>App.xaml</DependentUpon>
    </Compile>
    <Compile Update="AppShell.xaml.cs">
      <DependentUpon>AppShell.xaml</DependentUpon>
    </Compile>
    <Compile Update="Platforms\Windows\App.xaml.cs">
      <DependentUpon>App.xaml</DependentUpon>
    </Compile>
    <Compile Update="Pages\Identity\ChangePasswordPage.xaml.cs">
      <DependentUpon>ChangePasswordPage.xaml</DependentUpon>
    </Compile>
    <Compile Update="Pages\Identity\ForgotPasswordPage.xaml.cs">
      <DependentUpon>ForgotPasswordPage.xaml</DependentUpon>
    </Compile>
    <Compile Update="Pages\Identity\LoginPage.xaml.cs">
      <DependentUpon>LoginPage.xaml</DependentUpon>
    </Compile>
    <Compile Update="Pages\Identity\RegisterPage.xaml.cs">
      <DependentUpon>RegisterPage.xaml</DependentUpon>
    </Compile>
    <Compile Update="Pages\Identity\ResetPasswordPage.xaml.cs">
      <DependentUpon>ResetPasswordPage.xaml</DependentUpon>
    </Compile>
    <Compile Update="Pages\Identity\UserProfilePage.xaml.cs">
      <DependentUpon>UserProfilePage.xaml</DependentUpon>
    </Compile>
    <Compile Update="Pages\Identity\UsersOverviewPage.xaml.cs">
      <DependentUpon>UsersOverviewPage.xaml</DependentUpon>
    </Compile>
    <Compile Update="Pages\MealPlans\MealPlanEditPage.xaml.cs">
      <DependentUpon>MealPlanEditPage.xaml</DependentUpon>
    </Compile>
    <Compile Update="Pages\MealPlans\MealPlansOverviewPage.xaml.cs">
      <DependentUpon>MealPlansOverviewPage.xaml</DependentUpon>
    </Compile>
    <Compile Update="Pages\MealPlans\ShopEditPage.xaml.cs">
      <DependentUpon>ShopEditPage.xaml</DependentUpon>
    </Compile>
    <Compile Update="Pages\MealPlans\ShoppingListEditPage.xaml.cs">
      <DependentUpon>ShoppingListEditPage.xaml</DependentUpon>
    </Compile>
    <Compile Update="Pages\MealPlans\ShoppingListsOverviewPage.xaml.cs">
      <DependentUpon>ShoppingListsOverviewPage.xaml</DependentUpon>
    </Compile>
    <Compile Update="Pages\MealPlans\ShopsOverviewPage.xaml.cs">
      <DependentUpon>ShopsOverviewPage.xaml</DependentUpon>
    </Compile>
    <Compile Update="Pages\RecipeBook\ProductCategoriesOverviewPage.xaml.cs">
      <DependentUpon>ProductCategoriesOverviewPage.xaml</DependentUpon>
    </Compile>
    <Compile Update="Pages\RecipeBook\ProductCategoryEditPage.xaml.cs">
      <DependentUpon>ProductCategoryEditPage.xaml</DependentUpon>
    </Compile>
    <Compile Update="Pages\RecipeBook\ProductEditPage.xaml.cs">
      <DependentUpon>ProductEditPage.xaml</DependentUpon>
    </Compile>
    <Compile Update="Pages\RecipeBook\ProductsOverviewPage.xaml.cs">
      <DependentUpon>ProductsOverviewPage.xaml</DependentUpon>
    </Compile>
    <Compile Update="Pages\RecipeBook\ProductStatisticsPage.xaml.cs">
      <DependentUpon>ProductStatisticsPage.xaml</DependentUpon>
    </Compile>
    <Compile Update="Pages\RecipeBook\RecipeCategoriesOverviewPage.xaml.cs">
