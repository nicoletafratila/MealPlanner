<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MealPlanner.UI.Mobile.ViewModels.Identity"
             xmlns:converters="clr-namespace:MealPlanner.UI.Mobile.Converters"
             xmlns:res="clr-namespace:MealPlanner.UI.Mobile.Pages.Identity.Resources"
             x:Class="MealPlanner.UI.Mobile.Pages.Identity.ChangePasswordPage"
             x:DataType="vm:ChangePasswordViewModel"
             Title="{x:Static res:ChangePasswordPage.PageTitle}">

    <VerticalStackLayout Padding="24" Spacing="12">
        <Label Text="{x:Static res:ChangePasswordPage.CurrentPasswordLabel}" Style="{StaticResource SectionHeaderLabel}" />
        <Entry Text="{Binding Model.CurrentPassword}" IsPassword="True" />

        <Label Text="{x:Static res:ChangePasswordPage.NewPasswordLabel}" Style="{StaticResource SectionHeaderLabel}" />
        <Entry Text="{Binding Model.NewPassword}" IsPassword="True" />

        <Label Text="{x:Static res:ChangePasswordPage.ConfirmNewPasswordLabel}" Style="{StaticResource SectionHeaderLabel}" />
        <Entry Text="{Binding Model.ConfirmPassword}" IsPassword="True" />

        <Label Text="{Binding ErrorMessage}" Style="{StaticResource ErrorLabel}"
               IsVisible="{Binding ErrorMessage, Converter={x:Static converters:StringNotNullConverter.Instance}}" />
        <Label Text="{Binding SuccessMessage}" TextColor="{StaticResource SuccessColor}"
               IsVisible="{Binding SuccessMessage, Converter={x:Static converters:StringNotNullConverter.Instance}}" />

        <Button Text="{x:Static res:ChangePasswordPage.ChangeButton}" Command="{Binding ChangeCommand}" IsEnabled="{Binding IsNotBusy}" Margin="0,8,0,0" />
        <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" />
    </VerticalStackLayout>
</ContentPage>
