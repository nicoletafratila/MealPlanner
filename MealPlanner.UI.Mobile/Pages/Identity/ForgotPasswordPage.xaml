<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MealPlanner.UI.Mobile.ViewModels.Identity"
             xmlns:converters="clr-namespace:MealPlanner.UI.Mobile.Converters"
             x:Class="MealPlanner.UI.Mobile.Pages.Identity.ForgotPasswordPage"
             x:DataType="vm:ForgotPasswordViewModel"
             Title="Forgot Password">

    <VerticalStackLayout Padding="24" Spacing="16">
        <Label Text="Reset your password" Style="{StaticResource PageTitleLabel}" />
        <Label Text="Enter your email and we'll send you a reset link."
               TextColor="{StaticResource DarkGray}" />

        <Label Text="Email" Style="{StaticResource SectionHeaderLabel}" />
        <Entry Text="{Binding Model.EmailAddress}" Placeholder="Email address" Keyboard="Email" />

        <Label Text="{Binding ErrorMessage}" Style="{StaticResource ErrorLabel}"
               IsVisible="{Binding ErrorMessage, Converter={x:Static converters:StringNotNullConverter.Instance}}" />
        <Label Text="{Binding SuccessMessage}" TextColor="{StaticResource SuccessColor}"
               IsVisible="{Binding SuccessMessage, Converter={x:Static converters:StringNotNullConverter.Instance}}" />

        <Button Text="Send Reset Link" Command="{Binding SendCommand}" IsEnabled="{Binding IsNotBusy}" />
        <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" />
    </VerticalStackLayout>
</ContentPage>
