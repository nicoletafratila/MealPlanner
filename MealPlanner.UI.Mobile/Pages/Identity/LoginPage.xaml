<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MealPlanner.UI.Mobile.ViewModels.Identity"
             xmlns:converters="clr-namespace:MealPlanner.UI.Mobile.Converters"
             xmlns:res="clr-namespace:MealPlanner.UI.Mobile.Pages.Identity.Resources"
             x:Class="MealPlanner.UI.Mobile.Pages.Identity.LoginPage"
             x:DataType="vm:LoginViewModel"
             Title="{x:Static res:LoginPage.PageTitle}"
             Shell.NavBarIsVisible="False"
             Shell.FlyoutBehavior="Disabled">

    <ScrollView>
        <VerticalStackLayout Padding="32,60,32,32" Spacing="16">

            <Label Text="{x:Static res:LoginPage.AppName}" FontSize="32" FontAttributes="Bold"
                   TextColor="{StaticResource Primary}" HorizontalOptions="Center" />
            <Label Text="{x:Static res:LoginPage.Subtitle}" TextColor="{StaticResource DarkGray}"
                   HorizontalOptions="Center" Margin="0,0,0,24" />

            <Label Text="{x:Static res:LoginPage.UsernameLabel}" Style="{StaticResource SectionHeaderLabel}" />
            <Entry Text="{Binding Username}" Placeholder="{x:Static res:LoginPage.PlaceholderUsername}"
                   ReturnType="Next" />

            <Label Text="{x:Static res:LoginPage.PasswordLabel}" Style="{StaticResource SectionHeaderLabel}" />
            <Entry Text="{Binding Password}" Placeholder="{x:Static res:LoginPage.PlaceholderPassword}"
                   IsPassword="True" ReturnType="Go"
                   ReturnCommand="{Binding LoginCommand}" />

            <HorizontalStackLayout Spacing="8">
                <CheckBox IsChecked="{Binding RememberMe}" VerticalOptions="Center" />
                <Label Text="{x:Static res:LoginPage.RememberMeLabel}" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <Label Text="{Binding ErrorMessage}" Style="{StaticResource ErrorLabel}"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static converters:StringNotNullConverter.Instance}}" />

            <Button Text="{x:Static res:LoginPage.LoginButton}" Command="{Binding LoginCommand}"
                    IsEnabled="{Binding IsNotBusy}" Margin="0,8,0,0" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center" />

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4" Margin="0,16,0,0">
                <Label Text="{x:Static res:LoginPage.NoAccountLabel}" VerticalOptions="Center" />
                <Button Text="{x:Static res:LoginPage.RegisterButton}" Style="{StaticResource OutlineButton}"
                        Command="{Binding GoToRegisterCommand}" Padding="8,4" />
            </HorizontalStackLayout>

            <Button Text="{x:Static res:LoginPage.ForgotPasswordButton}" Style="{StaticResource OutlineButton}"
                    Command="{Binding GoToForgotPasswordCommand}"
                    HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
