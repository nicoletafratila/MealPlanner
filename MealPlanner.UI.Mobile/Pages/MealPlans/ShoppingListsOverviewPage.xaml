<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MealPlanner.UI.Mobile.ViewModels.MealPlans"
             xmlns:model="clr-namespace:MealPlanner.Shared.Models;assembly=MealPlanner.Shared"
             xmlns:res="clr-namespace:MealPlanner.UI.Mobile.Pages.MealPlans.Resources"
             x:Class="MealPlanner.UI.Mobile.Pages.MealPlans.ShoppingListsOverviewPage"
             x:DataType="vm:ShoppingListsOverviewViewModel"
             Title="{x:Static res:ShoppingListsOverviewPage.PageTitle}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="+" Command="{Binding AddCommand}" />
    </ContentPage.ToolbarItems>

    <RefreshView Command="{Binding LoadCommand}" IsRefreshing="{Binding IsBusy, Mode=OneWay}">
        <CollectionView ItemsSource="{Binding ShoppingLists}">
            <CollectionView.EmptyView>
                <Label Text="{x:Static res:ShoppingListsOverviewPage.EmptyLabel}" HorizontalOptions="Center" VerticalOptions="Center"
                       TextColor="{StaticResource DarkGray}" Margin="0,40" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="model:ShoppingListModel">
                    <SwipeView Margin="12,4">
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="🗑" BackgroundColor="{StaticResource ErrorColor}"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ShoppingListsOverviewViewModel}}, Path=DeleteCommand}"
                                           CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.RightItems>
                        <Frame Style="{StaticResource CardFrame}">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ShoppingListsOverviewViewModel}}, Path=EditCommand}"
                                    CommandParameter="{Binding .}" />
                            </Frame.GestureRecognizers>
                            <Label Text="{Binding Name}" FontAttributes="Bold" />
                        </Frame>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </RefreshView>
</ContentPage>
