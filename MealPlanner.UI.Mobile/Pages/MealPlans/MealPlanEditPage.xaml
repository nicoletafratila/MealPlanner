<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MealPlanner.UI.Mobile.ViewModels.MealPlans"
             xmlns:model="clr-namespace:RecipeBook.Shared.Models;assembly=RecipeBook.Shared"
             xmlns:converters="clr-namespace:MealPlanner.UI.Mobile.Converters"
             xmlns:res="clr-namespace:MealPlanner.UI.Mobile.Pages.MealPlans.Resources"
             x:Class="MealPlanner.UI.Mobile.Pages.MealPlans.MealPlanEditPage"
             x:DataType="vm:MealPlanEditViewModel"
             Title="{Binding IsNew, Converter={x:Static converters:BoolToStringConverter.Instance}, ConverterParameter='New Meal Plan|Edit Meal Plan'}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="{x:Static res:MealPlanEditPage.SaveButton}" Command="{Binding SaveCommand}" />
        <ToolbarItem Text="🗑" Command="{Binding DeleteCommand}"
                     IsDestructive="True"
                     IsEnabled="{Binding IsNew, Converter={x:Static converters:InvertBoolConverter.Instance}}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" />

            <!-- Name -->
            <Label Text="{x:Static res:MealPlanEditPage.NameLabel}" Style="{StaticResource SectionHeaderLabel}" />
            <Entry Text="{Binding Model.Name}" Placeholder="{x:Static res:MealPlanEditPage.PlaceholderName}" />

            <!-- Recipe selection -->
            <Label Text="{x:Static res:MealPlanEditPage.AddRecipeLabel}" Style="{StaticResource SectionHeaderLabel}" />
            <Picker Title="{x:Static res:MealPlanEditPage.FilterByCategoryTitle}"
                    ItemsSource="{Binding Categories}"
                    SelectedItem="{Binding SelectedCategory}"
                    ItemDisplayBinding="{Binding Name}" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Border Grid.Column="0"
                        Stroke="{StaticResource MidGray}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 8"
                        Padding="10,0"
                        MinimumHeightRequest="44"
                        VerticalOptions="Center"
                        BackgroundColor="{AppThemeBinding Light={StaticResource LightGray}, Dark=#2A2A2A}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSelectRecipeTapped" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Label Grid.Column="0" VerticalOptions="Center"
                               LineBreakMode="TailTruncation"
                               Text="{Binding SelectedRecipe.Name, TargetNullValue={x:Static res:MealPlanEditPage.SelectRecipeTitle}}">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding SelectedRecipe}" Value="{x:Null}">
                                    <Setter Property="TextColor" Value="{StaticResource DarkGray}" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                        <Label Grid.Column="1" Text="&#x25BE;" VerticalOptions="Center"
                               FontSize="14" TextColor="{StaticResource DarkGray}" />
                    </Grid>
                </Border>
                <Button Grid.Column="1" Text="{x:Static res:MealPlanEditPage.AddButton}"
                        Command="{Binding AddRecipeCommand}"
                        IsEnabled="{Binding SelectedRecipe, Converter={x:Static converters:NotNullConverter.Instance}}"
                        Padding="14,10" />
            </Grid>

            <!-- Recipes in plan -->
            <Label Text="{x:Static res:MealPlanEditPage.RecipesInPlanLabel}" Style="{StaticResource SectionHeaderLabel}" />
            <CollectionView ItemsSource="{Binding PlanRecipes}" SelectionMode="None">
                <CollectionView.EmptyView>
                    <Label Text="{x:Static res:MealPlanEditPage.EmptyRecipes}" TextColor="{StaticResource DarkGray}" Margin="0,4" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="model:RecipeModel">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" Padding="0,4">
                            <Image Grid.Column="0"
                                   Source="{Binding ImageUrl}"
                                   WidthRequest="32" HeightRequest="32"
                                   Aspect="AspectFill"
                                   IsVisible="{Binding ImageUrl, Converter={x:Static converters:StringNotNullConverter.Instance}}" />
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                <Label Text="{Binding Name}" FontAttributes="Bold" />
                                <Label Text="{Binding EffectiveCategoryName}" FontSize="12" TextColor="{StaticResource DarkGray}" />
                            </VerticalStackLayout>
                            <Button Grid.Column="2" Text="🗑" BackgroundColor="Transparent"
                                    Padding="8,4"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MealPlanEditViewModel}}, Path=RemoveRecipeCommand}"
                                    CommandParameter="{Binding .}" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Make shopping list -->
            <Button Text="{x:Static res:MealPlanEditPage.MakeShoppingListButton}"
                    Style="{StaticResource OutlineButton}"
                    Command="{Binding MakeShoppingListCommand}"
                    IsEnabled="{Binding IsNew, Converter={x:Static converters:InvertBoolConverter.Instance}}"
                    Margin="0,8,0,0" />

            <Label Text="{Binding ErrorMessage}" Style="{StaticResource ErrorLabel}"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static converters:StringNotNullConverter.Instance}}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
