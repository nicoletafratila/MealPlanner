<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MealPlanner.UI.Mobile.ViewModels.MealPlans"
             xmlns:model="clr-namespace:RecipeBook.Shared.Models;assembly=RecipeBook.Shared"
             xmlns:converters="clr-namespace:MealPlanner.UI.Mobile.Converters"
             x:Class="MealPlanner.UI.Mobile.Pages.MealPlans.MealPlanEditPage"
             x:DataType="vm:MealPlanEditViewModel"
             Title="{Binding IsNew, Converter={x:Static converters:BoolToStringConverter.Instance}, ConverterParameter='New Meal Plan|Edit Meal Plan'}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Save" Command="{Binding SaveCommand}" />
        <ToolbarItem Text="🗑" Command="{Binding DeleteCommand}"
                     IsDestructive="True"
                     IsEnabled="{Binding IsNew, Converter={x:Static converters:InvertBoolConverter.Instance}}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" />

            <!-- Name -->
            <Label Text="Name" Style="{StaticResource SectionHeaderLabel}" />
            <Entry Text="{Binding Model.Name}" Placeholder="Meal plan name" />

            <!-- Recipe selection -->
            <Label Text="Add recipe" Style="{StaticResource SectionHeaderLabel}" />
            <Picker Title="Filter by category"
                    ItemsSource="{Binding Categories}"
                    SelectedItem="{Binding SelectedCategory}"
                    ItemDisplayBinding="{Binding Name}" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Picker Grid.Column="0"
                        Title="Select recipe"
                        ItemsSource="{Binding FilteredRecipes}"
                        SelectedItem="{Binding SelectedRecipe}"
                        ItemDisplayBinding="{Binding Name}" />
                <Button Grid.Column="1" Text="Add"
                        Command="{Binding AddRecipeCommand}"
                        IsEnabled="{Binding SelectedRecipe, Converter={x:Static converters:NotNullConverter.Instance}}"
                        Padding="14,10" />
            </Grid>

            <!-- Recipes in plan -->
            <Label Text="Recipes in plan" Style="{StaticResource SectionHeaderLabel}" />
            <CollectionView ItemsSource="{Binding Model.Recipes}" SelectionMode="None">
                <CollectionView.EmptyView>
                    <Label Text="No recipes added yet." TextColor="{StaticResource DarkGray}" Margin="0,4" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="model:RecipeModel">
                        <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                <Label Text="{Binding Name}" FontAttributes="Bold" />
                                <Label Text="{Binding EffectiveCategoryName}" FontSize="12" TextColor="{StaticResource DarkGray}" />
                            </VerticalStackLayout>
                            <Button Grid.Column="1" Text="✕" Style="{StaticResource DangerButton}"
                                    Padding="8,4"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MealPlanEditViewModel}}, Path=RemoveRecipeCommand}"
                                    CommandParameter="{Binding .}" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Make shopping list -->
            <Button Text="Make Shopping List"
                    Style="{StaticResource OutlineButton}"
                    Command="{Binding MakeShoppingListCommand}"
                    IsEnabled="{Binding IsNew, Converter={x:Static converters:InvertBoolConverter.Instance}}"
                    Margin="0,8,0,0" />

            <Label Text="{Binding ErrorMessage}" Style="{StaticResource ErrorLabel}"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static converters:StringNotNullConverter.Instance}}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
