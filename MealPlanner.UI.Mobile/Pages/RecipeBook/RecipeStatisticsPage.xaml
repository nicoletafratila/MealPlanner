<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MealPlanner.UI.Mobile.ViewModels.RecipeBook"
             xmlns:converters="clr-namespace:MealPlanner.UI.Mobile.Converters"
             x:Class="MealPlanner.UI.Mobile.Pages.RecipeBook.RecipeStatisticsPage"
             x:DataType="vm:RecipeStatisticsViewModel"
             Title="Recipe Statistics">

    <RefreshView Command="{Binding LoadCommand}" IsRefreshing="{Binding IsBusy}">
        <CollectionView ItemsSource="{Binding Entries}" SelectionMode="None" Margin="16,8">
            <CollectionView.EmptyView>
                <Label Text="No statistics available." HorizontalOptions="Center"
                       TextColor="{StaticResource DarkGray}" Margin="0,40" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:StatisticEntryModel">
                    <VerticalStackLayout>
                        <!-- Group header -->
                        <Label Text="{Binding GroupTitle}"
                               FontAttributes="Bold" FontSize="15"
                               Margin="0,16,0,6"
                               IsVisible="{Binding IsGroupHeader}" />

                        <!-- Data row -->
                        <Grid ColumnDefinitions="140,*,40" ColumnSpacing="8" Margin="0,3"
                              IsVisible="{Binding IsGroupHeader, Converter={x:Static converters:InvertBoolConverter.Instance}}">
                            <Label Grid.Column="0" Text="{Binding ItemName}"
                                   FontSize="13" VerticalOptions="Center"
                                   LineBreakMode="TailTruncation" />
                            <ProgressBar Grid.Column="1"
                                         Progress="{Binding BarFraction}"
                                         ProgressColor="{StaticResource Primary}"
                                         VerticalOptions="Center" />
                            <Label Grid.Column="2"
                                   Text="{Binding Value, StringFormat='{0:0}'}"
                                   FontSize="12" TextColor="{StaticResource DarkGray}"
                                   HorizontalOptions="End" VerticalOptions="Center" />
                        </Grid>
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </RefreshView>
</ContentPage>
