<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MealPlanner.UI.Mobile.ViewModels.RecipeBook"
             xmlns:converters="clr-namespace:MealPlanner.UI.Mobile.Converters"
             xmlns:controls="clr-namespace:MealPlanner.UI.Mobile.Controls"
             xmlns:res="clr-namespace:MealPlanner.UI.Mobile.Pages.RecipeBook.Resources"
             x:Class="MealPlanner.UI.Mobile.Pages.RecipeBook.RecipeStatisticsPage"
             x:DataType="vm:RecipeStatisticsViewModel"
             Title="{x:Static res:RecipeStatisticsPage.PageTitle}">

    <RefreshView Command="{Binding LoadCommand}" IsRefreshing="{Binding IsBusy, Mode=OneWay}">
        <Grid RowDefinitions="*,Auto" RowSpacing="4">
            <CarouselView Grid.Row="0"
                          ItemsSource="{Binding Categories}"
                          IndicatorView="PageIndicator"
                          Loop="False">
                <CarouselView.EmptyView>
                    <Label Text="{x:Static res:RecipeStatisticsPage.EmptyLabel}" HorizontalOptions="Center"
                           VerticalOptions="Center" TextColor="{StaticResource DarkGray}" />
                </CarouselView.EmptyView>
                <CarouselView.ItemTemplate>
                    <DataTemplate x:DataType="vm:CategoryStatisticModel">
                        <ScrollView Padding="16,8">
                            <VerticalStackLayout Spacing="14">
                                <Frame Style="{StaticResource CardFrame}">
                                    <Grid ColumnDefinitions="76,*" ColumnSpacing="16">
                                        <controls:DonutShareView Grid.Column="0"
                                                                  WidthRequest="72" HeightRequest="72"
                                                                  Percentage="{Binding SharePercentage}"
                                                                  RingColor="{StaticResource Primary}"
                                                                  TrackColor="{StaticResource MidGray}" />
                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                            <Label Text="{Binding Title}" FontSize="19" FontAttributes="Bold"
                                                   LineBreakMode="TailTruncation" />
                                            <HorizontalStackLayout Spacing="4">
                                                <Label Text="{Binding SharePercentage, StringFormat='{0:0}%'}"
                                                       FontSize="13" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                                                <Label Text="{x:Static res:RecipeStatisticsPage.ShareOfFavoritesLabel}"
                                                       FontSize="13" TextColor="{StaticResource DarkGray}" />
                                            </HorizontalStackLayout>
                                            <HorizontalStackLayout Spacing="4">
                                                <Label Text="{Binding TotalValue, StringFormat='{0:0}'}"
                                                       FontSize="12" FontAttributes="Bold" TextColor="{StaticResource DarkGray}" />
                                                <Label Text="{x:Static res:RecipeStatisticsPage.TotalCountLabel}"
                                                       FontSize="12" TextColor="{StaticResource DarkGray}" />
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Frame>

                                <CollectionView ItemsSource="{Binding Items}" SelectionMode="None">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="vm:RankedStatisticItemModel">
                                            <Grid ColumnDefinitions="34,*,44" ColumnSpacing="10" Margin="0,5">
                                                <Border Grid.Column="0" WidthRequest="30" HeightRequest="30"
                                                        StrokeShape="RoundRectangle 15" Stroke="Transparent"
                                                        BackgroundColor="{Binding Rank, Converter={x:Static converters:RankToBadgeColorConverter.Instance}}"
                                                        HorizontalOptions="Center" VerticalOptions="Center">
                                                    <Label Text="{Binding Rank, Converter={x:Static converters:RankToBadgeTextConverter.Instance}}"
                                                           FontSize="13" FontAttributes="Bold" TextColor="{StaticResource White}"
                                                           HorizontalOptions="Center" VerticalOptions="Center"
                                                           HorizontalTextAlignment="Center" />
                                                </Border>
                                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="3">
                                                    <Label Text="{Binding ItemName}" FontSize="13" LineBreakMode="TailTruncation" />
                                                    <ProgressBar Progress="{Binding BarFraction}"
                                                                 ProgressColor="{StaticResource Primary}" HeightRequest="6" />
                                                </VerticalStackLayout>
                                                <Label Grid.Column="2" Text="{Binding Value, StringFormat='{0:0}'}"
                                                       FontSize="13" FontAttributes="Bold" TextColor="{StaticResource DarkGray}"
                                                       HorizontalOptions="End" VerticalOptions="Center" />
                                            </Grid>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>
                        </ScrollView>
                    </DataTemplate>
                </CarouselView.ItemTemplate>
            </CarouselView>

            <IndicatorView x:Name="PageIndicator" Grid.Row="1"
                           IndicatorColor="{StaticResource MidGray}"
                           SelectedIndicatorColor="{StaticResource Primary}"
                           HorizontalOptions="Center" Margin="0,4,0,10" />
        </Grid>
    </RefreshView>
</ContentPage>
