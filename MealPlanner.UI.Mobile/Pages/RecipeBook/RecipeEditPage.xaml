<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MealPlanner.UI.Mobile.ViewModels.RecipeBook"
             xmlns:converters="clr-namespace:MealPlanner.UI.Mobile.Converters"
             x:Class="MealPlanner.UI.Mobile.Pages.RecipeBook.RecipeEditPage"
             x:DataType="vm:RecipeEditViewModel"
             Title="{Binding IsNew, Converter={x:Static converters:BoolToStringConverter.Instance}, ConverterParameter='New Recipe|Edit Recipe'}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Save" Command="{Binding SaveCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" />

            <Label Text="Name" Style="{StaticResource SectionHeaderLabel}" />
            <Entry Text="{Binding Model.Name}" Placeholder="Recipe name" />

            <Label Text="Category" Style="{StaticResource SectionHeaderLabel}" />
            <Picker ItemsSource="{Binding Categories}"
                    SelectedItem="{Binding SelectedCategory}"
                    ItemDisplayBinding="{Binding Name}"
                    Title="Select category" />

            <Label Text="Source" Style="{StaticResource SectionHeaderLabel}" />
            <Entry Text="{Binding Model.Source}" Placeholder="Optional source / URL" />

            <Label Text="Image" Style="{StaticResource SectionHeaderLabel}" />
            <Button Text="Pick Image" Command="{Binding PickImageCommand}" HorizontalOptions="Start" />
            <Image Source="{Binding RecipeImage}" HeightRequest="150" Aspect="AspectFit"
                   IsVisible="{Binding RecipeImage, Converter={x:Static converters:NotNullConverter.Instance}}" />

            <Label Text="Ingredients" Style="{StaticResource SectionHeaderLabel}" />
            <CollectionView ItemsSource="{Binding RecipeIngredients}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:RecipeIngredientEditViewModel">
                        <Grid ColumnDefinitions="*,Auto,80,Auto" Spacing="8" Padding="0,4">
                            <Border Grid.Column="0"
                                    Stroke="{StaticResource MidGray}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="10,0"
                                    MinimumHeightRequest="44"
                                    VerticalOptions="Center"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource LightGray}, Dark=#2A2A2A}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnSelectProductTapped" CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                    <Image Grid.Column="0"
                                           Source="{Binding SelectedProduct.ImageUrl}"
                                           WidthRequest="26" HeightRequest="26"
                                           Aspect="AspectFill" VerticalOptions="Center"
                                           IsVisible="{Binding SelectedProduct.ImageUrl, Converter={x:Static converters:StringNotNullConverter.Instance}}" />
                                    <Label Grid.Column="1" VerticalOptions="Center"
                                           LineBreakMode="TailTruncation"
                                           Text="{Binding SelectedProduct.Name, TargetNullValue='Select product'}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding SelectedProduct}" Value="{x:Null}">
                                                <Setter Property="TextColor" Value="{StaticResource DarkGray}" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                    <Label Grid.Column="2" Text="&#x25BE;" VerticalOptions="Center"
                                           FontSize="14" TextColor="{StaticResource DarkGray}" />
                                </Grid>
                            </Border>
                            <Picker Grid.Column="1" Title="Unit"
                                    ItemsSource="{Binding CompatibleUnits}"
                                    SelectedItem="{Binding SelectedUnit}"
                                    ItemDisplayBinding="{Binding Name}" />
                            <Entry Grid.Column="2" Text="{Binding Quantity, StringFormat='{0}'}"
                                   Keyboard="Numeric" Placeholder="Qty" />
                            <Button Grid.Column="3" Text="✕" Style="{StaticResource DangerButton}"
                                    Padding="8,4"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveIngredientCommand}"
                                    CommandParameter="{Binding .}" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="+ Add Ingredient" Style="{StaticResource OutlineButton}"
                    Command="{Binding AddIngredientCommand}" />

            <Label Text="{Binding ErrorMessage}" Style="{StaticResource ErrorLabel}"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static converters:StringNotNullConverter.Instance}}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
