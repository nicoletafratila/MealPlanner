<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MealPlanner.UI.Mobile.ViewModels.RecipeBook"
             xmlns:model="clr-namespace:RecipeBook.Shared.Models;assembly=RecipeBook.Shared"
             xmlns:converters="clr-namespace:MealPlanner.UI.Mobile.Converters"
             x:Class="MealPlanner.UI.Mobile.Pages.RecipeBook.RecipesOverviewPage"
             x:DataType="vm:RecipesOverviewViewModel"
             Title="Recipes">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="+" Command="{Binding AddRecipeCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <!-- Search -->
        <SearchBar Grid.Row="0" Placeholder="Search recipes..."
                   Text="{Binding SearchText}"
                   SearchCommand="{Binding SearchCommand}"
                   Margin="12,8" />

        <!-- Category filter -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="12,0,12,8">
            <Picker Grid.Column="0" Title="All categories"
                    ItemsSource="{Binding Categories}"
                    SelectedItem="{Binding SelectedCategory}"
                    ItemDisplayBinding="{Binding Name}" />
            <Button Grid.Column="1" Text="✕"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource DarkGray}"
                    FontSize="16"
                    Padding="8,0"
                    MinimumHeightRequest="0"
                    IsVisible="{Binding SelectedCategory, Converter={x:Static converters:NotNullConverter.Instance}}"
                    Command="{Binding ClearCategoryCommand}" />
        </Grid>

        <!-- Recipe list -->
        <RefreshView Grid.Row="2" Command="{Binding LoadCommand}" IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Recipes}" SelectionMode="None">
                <CollectionView.EmptyView>
                    <Label Text="No recipes found." HorizontalOptions="Center"
                           VerticalOptions="Center" TextColor="{StaticResource DarkGray}" Margin="0,40" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="model:RecipeModel">
                        <SwipeView Margin="12,4">
                            <SwipeView.RightItems>
                                <SwipeItems>
                                    <SwipeItem Text="Delete" BackgroundColor="{StaticResource ErrorColor}"
                                               Command="{Binding Source={RelativeSource AncestorType={x:Type vm:RecipesOverviewViewModel}}, Path=DeleteRecipeCommand}"
                                               CommandParameter="{Binding .}" />
                                </SwipeItems>
                            </SwipeView.RightItems>
                            <Frame Style="{StaticResource CardFrame}" Padding="0">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:RecipesOverviewViewModel}}, Path=OpenRecipeCommand}"
                                        CommandParameter="{Binding .}" />
                                </Frame.GestureRecognizers>
                                <VerticalStackLayout Spacing="0">
                                    <Image Source="{Binding ImageUrl}"
                                           HeightRequest="160"
                                           Aspect="AspectFill"
                                           HorizontalOptions="Fill" />
                                    <VerticalStackLayout Padding="12,8" Spacing="4">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Grid.Column="0" Text="{Binding Name}" FontAttributes="Bold" VerticalOptions="Center" />
                                            <Button Grid.Column="1" Text="↗"
                                                    BackgroundColor="Transparent"
                                                    TextColor="{StaticResource Primary}"
                                                    FontSize="16"
                                                    Padding="4,0"
                                                    MinimumHeightRequest="0"
                                                    IsVisible="{Binding Source, Converter={x:Static converters:StringNotNullConverter.Instance}}"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:RecipesOverviewViewModel}}, Path=OpenSourceCommand}"
                                                    CommandParameter="{Binding Source}" />
                                        </Grid>
                                        <Label Text="{Binding RecipeCategoryName}"
                                               FontSize="12" TextColor="{StaticResource DarkGray}" />
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Frame>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <Label Grid.Row="3" Text="{Binding ErrorMessage}" Style="{StaticResource ErrorLabel}"
               IsVisible="{Binding ErrorMessage, Converter={x:Static converters:StringNotNullConverter.Instance}}"
               Margin="12,4" />
    </Grid>
</ContentPage>
