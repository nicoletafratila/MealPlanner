@page "/identities/userprofile"
@page "/identities/userprofile/{name}"

<Breadcrumb style="--bs-breadcrumb-divider: '>';" Items="_navItems"></Breadcrumb>

<style>
    .img-profile {
        max-width: 200px;
        max-height: 200px;
    }
</style>

@if (ApplicationUser != null)
{
    <div class="card">
        <div class="card-header">
            <table>
                <tr class="row g-0" style="display:contents">
                    <td style="vertical-align: top">
                        <h2 id="headerfirstname">@ApplicationUser.FirstName</h2>
                        <br />
                        <h2 id="headerlastname">@ApplicationUser.LastName</h2>
                    </td>
                    <td style="align-content:flex-end;">
                        <img class="img-profile" src="@ApplicationUser.ProfilePictureUrl" />
                    </td>
                </tr>
            </table>
        </div>

        <div class="card-body">
            <EditForm Model="@ApplicationUser" OnValidSubmit="@SaveAsync">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="form-group">
                    <label for="username" class="col-sm-3">@Resources.UserProfile.UsernameLabel</label>
                    <InputText disabled id="username" class="form-control" @bind-Value="@ApplicationUser.Username"></InputText>
                    <ValidationMessage For="@(() => ApplicationUser.Username)" />
                </div>

                <div class="form-group mt-3">
                    <label for="firstname" class="col-sm-3">@Resources.UserProfile.FirstNameLabel</label>
                    <InputText id="firstname" class="form-control" @bind-Value="@ApplicationUser.FirstName" placeholder="@Resources.UserProfile.PlaceholderFirstName" oninput="updateHeader()"></InputText>
                    <ValidationMessage For="@(() => ApplicationUser.FirstName)" />
                </div>

                <div class="form-group mt-3">
                    <label for="lastname" class="col-sm-3">@Resources.UserProfile.LastNameLabel</label>
                    <InputText id="lastname" class="form-control" @bind-Value="@ApplicationUser.LastName" placeholder="@Resources.UserProfile.PlaceholderLastName" oninput="updateHeader()"></InputText>
                    <ValidationMessage For="@(() => ApplicationUser.LastName)" />
                </div>

                <div class="form-group mt-3">
                    <label for="phonenumber" class="col-sm-3">@Resources.UserProfile.PhoneNumberLabel</label>
                    <InputText id="phonenumber" class="form-control" @bind-Value="@ApplicationUser.PhoneNumber" placeholder="@Resources.UserProfile.PlaceholderPhoneNumber"></InputText>
                    <ValidationMessage For="@(() => ApplicationUser.PhoneNumber)" />
                </div>

                <div class="form-group mt-3">
                    <label for="email" class="col-sm-3">@Resources.UserProfile.EmailLabel</label>
                    <InputText id="email" class="form-control" @bind-Value="@ApplicationUser.EmailAddress" placeholder="@Resources.UserProfile.PlaceholderEmail"></InputText>
                    <ValidationMessage For="@(() => ApplicationUser.EmailAddress)" />
                </div>

                <div class="form-group mt-3">
                    <label for="image" class="col-sm-3">@Resources.UserProfile.SelectImageLabel</label>
                    <InputFile id="image" class="form-control" OnChange="OnInputFileChangeAsync" accept="image/png, image/jpeg, image/gif" />
                    <ValidationMessage For="@(() => ApplicationUser.ProfilePicture)" />
                </div>

                <AuthorizeView Roles="admin" Context="authContext">
                    <div class="form-group mt-3">
                        <label class="col-sm-3" style="width: 5%">@Resources.UserProfile.IsActiveLabel</label>
                        <InputCheckbox id="isactive" class="form-check-input" @bind-Value="@ApplicationUser.IsActive" />
                    </div>
                </AuthorizeView>

                <div class="form-group mt-3">
                    <button type="submit" class="btn btn-primary btn-sm">@Resources.UserProfile.SaveButton</button>
                    <button class="btn btn-primary btn-sm" type="button" @onclick="NavigateToChangePassword">@Resources.UserProfile.ChangePasswordButton</button>
                    <button class="btn btn-primary btn-sm" type="button" @onclick="NavigateToOverview">@Resources.UserProfile.BackToOverviewButton</button>
                </div>
            </EditForm>
        </div>
    </div>
}

<script>
    function updateHeader() {
        var inputFirstName = document.getElementById("firstname").value;
        document.getElementById("headerfirstname").innerText = inputFirstName;

         var inputLastName = document.getElementById("lastname").value;
        document.getElementById("headerlastname").innerText = inputLastName;
    }
</script>