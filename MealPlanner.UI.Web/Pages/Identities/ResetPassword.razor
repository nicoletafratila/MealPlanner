@page "/identities/reset-password"

<style>
    .reset-password-background {
        background-image: url('images/loginbackground.jpg');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 800px;
        text-align: center;
    }

    .reset-password-form {
        background: rgba(255, 255, 255, 0.85);
        padding: 2rem;
        border-radius: 8px;
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
        align-content: center;
        text-align: left;
        max-width: 400px;
        margin: 3rem auto;
    }

    .col-sm-3 {
        width: auto;
    }
</style>

<div class="reset-password-background">
    @if (_invalidLink)
    {
        <div class="reset-password-form">
            <p class="text-danger">@Resources.ResetPassword.InvalidLink</p>
            <button type="button" class="btn btn-secondary btn-sm mt-2" @onclick="NavigateToLogin">@Resources.ResetPassword.BackToLoginLink</button>
        </div>
    }
    else
    {
        <EditForm Model="ResetPasswordModel" OnValidSubmit="OnSubmitAsync" class="reset-password-form">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <h4 class="mb-3">@Resources.ResetPassword.PageTitle</h4>

            <div class="form-group">
                <label for="newpassword" class="col-sm-3">@Resources.ResetPassword.NewPasswordLabel</label>
                <PasswordInput id="newpassword" class="form-control" @bind-Value="@ResetPasswordModel.NewPassword" placeholder="@Resources.ResetPassword.PlaceholderNewPassword"></PasswordInput>
                <ValidationMessage For="@(() => ResetPasswordModel.NewPassword)" />
            </div>

            <div class="form-group mt-3">
                <label for="confirmpassword" class="col-sm-3">@Resources.ResetPassword.ConfirmPasswordLabel</label>
                <PasswordInput id="confirmpassword" class="form-control" @bind-Value="@ResetPasswordModel.ConfirmPassword" placeholder="@Resources.ResetPassword.PlaceholderConfirmPassword"></PasswordInput>
                <ValidationMessage For="@(() => ResetPasswordModel.ConfirmPassword)" />
            </div>

            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary btn-sm">@Resources.ResetPassword.SubmitButton</button>
                <button type="button" class="btn btn-secondary btn-sm" @onclick="NavigateToLogin">@Resources.ResetPassword.BackToLoginLink</button>
            </div>
        </EditForm>
    }
</div>
