@page "/identities/forgot-password"

<style>
    .forgot-password-background {
        background-image: url('images/loginbackground.jpg');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 800px;
        text-align: center;
    }

    .forgot-password-form {
        background: rgba(255, 255, 255, 0.85);
        padding: 2rem;
        border-radius: 8px;
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
        align-content: center;
        text-align: left;
        max-width: 400px;
        margin: 3rem auto;
    }
</style>

<div class="forgot-password-background">
    <EditForm Model="ForgotPasswordModel" OnValidSubmit="OnSubmitAsync" class="forgot-password-form">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <h4 class="mb-3">@Resources.ForgotPassword.PageTitle</h4>

        <div class="form-group">
            <label for="email" class="col-sm-3">@Resources.ForgotPassword.EmailLabel</label>
            <InputText id="email" class="form-control" @bind-Value="@ForgotPasswordModel.EmailAddress" placeholder="@Resources.ForgotPassword.PlaceholderEmail"></InputText>
            <ValidationMessage For="@(() => ForgotPasswordModel.EmailAddress)" />
        </div>

        <div class="mt-3 d-flex gap-2">
            <button type="submit" class="btn btn-primary btn-sm">@Resources.ForgotPassword.SubmitButton</button>
            <button type="button" class="btn btn-secondary btn-sm" @onclick="NavigateToLogin">@Resources.ForgotPassword.BackToLoginLink</button>
        </div>
    </EditForm>
</div>
