@page "/recipebooks/recipecategoryedit"
@page "/recipebooks/recipecategoryedit/{Id}"

<Breadcrumb style="--bs-breadcrumb-divider: '>';" Items="_navItems"></Breadcrumb>

@if (RecipeCategory != null)
{
    <div class="card">
        <div class="card-header">
            <table>
                <tr class="row g-0" style="display:contents">
                    <td class="col-md-8" style="vertical-align: top">
                        <h2 id="headerName">@RecipeCategory.Name</h2>
                    </td>
                </tr>
            </table>
        </div>

        <div class="card-body">
            <EditForm Model="@RecipeCategory" OnValidSubmit="@SaveAsync">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="form-group">
                    <label for="name" class="col-sm-3">@Resources.RecipeCategoryEdit.LabelRecipeCategoryName</label>
                    <InputText id="name" class="form-control" @bind-Value="@RecipeCategory.Name" placeholder="Enter recipe category name" oninput="updateHeader()"></InputText>
                    <ValidationMessage For="@(() => RecipeCategory.Name)" />
                </div>

                <div class="col mt-3">
                    <button class="btn btn-primary btn-sm" type="submit">@Resources.RecipeCategoryEdit.SaveButton</button>
                    <button class="btn btn-danger btn-sm" type="button" @onclick="async () => await DeleteAsync()">@Resources.RecipeCategoryEdit.DeleteButton</button>
                    <button class="btn btn-primary btn-sm" type="button" @onclick="NavigateToOverview">@Resources.RecipeCategoryEdit.BackToOverviewButton</button>
                </div>
            </EditForm>
        </div>
    </div>
}

<ConfirmDialog @ref="_dialog" />

<script>
    function updateHeader() {
        var input = document.getElementById("name").value;
        document.getElementById("headerName").innerText = input;
    }
</script>