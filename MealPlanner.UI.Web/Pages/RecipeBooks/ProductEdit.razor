@page "/recipebooks/productedit"
@page "/recipebooks/productedit/{id}"

<Breadcrumb style="--bs-breadcrumb-divider: '>';" Items="_navItems"></Breadcrumb>

<style>
    .img-product {
        max-width: 200px;
        max-height: 200px;
    }
</style>

@if (Product != null)
{
    <div class="card">
        <div class="card-header">
            <table>
                <tr class="row g-0" style="display:contents">
                    <td style="vertical-align: top">
                        <h2 id="headerName">@Product.Name</h2>
                    </td>
                    <td style="align-content:flex-end;">
                        <img class="img-product" src="@Product.ImageUrl" />
                    </td>
                </tr>
            </table>
        </div>

        <div class="card-body">
            <EditForm Model="@Product" OnValidSubmit="@SaveAsync">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="form-group">
                    <label for="name" class="col-sm-3">@Resources.ProductEdit.LabelProductName</label>
                    <InputText id="name" class="form-control" @bind-Value="@Product.Name" placeholder="Enter product name" oninput="updateHeader()"></InputText>
                    <ValidationMessage For="@(() => Product.Name)" />
                </div>

                <div class="form-group mt-3">
                    <label for="image" class="col-sm-3">@Resources.ProductEdit.LabelSelectImage</label>
                    <InputFile id="image" class="form-control" OnChange="OnInputFileChangeAsync" accept="image/png, image/jpeg, image/gif" />
                    <ValidationMessage For="@(() => Product.ImageContent)" />
                </div>

                <div class="form-group mt-3">
                    <label for="productCategory" class="col-sm-3">@Resources.ProductEdit.LabelProductCategory</label>
                    <InputSelect id="productCategory" class="form-select" @bind-Value="@Product.ProductCategoryId">
                        <option selected value="0">Choose...</option>
                        @if (Categories != null && Categories.Items != null && Categories.Items.Any())
                        {
                            @foreach (var category in Categories.Items!)
                            {
                                <option value="@category.Id">@category.Name</option>
                            }
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => Product.ProductCategoryId)" />
                </div>

                <div class="form-group mt-3">
                    <label for="unit" class="col-sm-3">@Resources.ProductEdit.LabelUnitOfMeasurement</label>
                    <InputSelect id="unit" class="form-select" @bind-Value="@Product.BaseUnitId">
                        <option selected value="0">Choose...</option>
                        @if (Units != null && Units.Items != null && Units.Items.Any())
                        {
                            @foreach (var unit in Units.Items!)
                            {
                                <option value="@unit.Id">@unit.Name</option>
                            }
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => Product.BaseUnitId)" />
                </div>

                <br />

                <button type="submit" class="btn btn-primary btn-sm">@Resources.ProductEdit.SaveButton</button>
                <button class="btn btn-danger btn-sm" type="button" @onclick="async () => await DeleteAsync()">@Resources.ProductEdit.DeleteButton</button>
                <button class="btn btn-primary btn-sm" type="button" @onclick="NavigateToOverview">@Resources.ProductEdit.BackToOverviewButton</button>
            </EditForm>
        </div>
    </div>
}

<ConfirmDialog @ref="_dialog" />

<script>
    function updateHeader() {
        var input = document.getElementById("name").value;
        document.getElementById("headerName").innerText = input;
    }
</script>