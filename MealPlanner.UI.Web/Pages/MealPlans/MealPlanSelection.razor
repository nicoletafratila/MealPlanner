<style>
    .blazored-modal {
        max-height: fit-content !important;
        max-width: fit-content !important;
        margin-top: 500px !important;
    }
</style>

<div class="modal-body">
    <div class="modal-title">
        <h5>@Resources.MealPlanSelection.Title</h5>
    </div>

    <div class="col">
        <EditForm Model="@this" OnValidSubmit="@SaveAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-group mt-3">
                <InputSelect id="Meal plan" class="form-select" @bind-Value="@MealPlanId">
                    <option selected value="0">@Resources.MealPlanSelection.ChooseOption</option>
                    @if (MealPlans != null && MealPlans.Items != null && MealPlans.Items.Any())
                    {
                        @foreach (var item in MealPlans.Items)
                        {
                            <option value="@item.Id">@item.Name</option>
                        }
                    }
                </InputSelect>
            </div>

            <div class="col mt-3">
                <button class="btn btn-primary btn-sm" type="submit">@Resources.MealPlanSelection.SaveButton</button>
                <button class="btn btn-danger btn-sm" @onclick="async ()=> await CancelAsync()">@Resources.MealPlanSelection.CancelButton</button>
            </div>
        </EditForm>
    </div>
</div>
