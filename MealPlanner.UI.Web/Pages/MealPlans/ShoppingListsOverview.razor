@page "/mealplans/shoppinglistsoverview"
@using MealPlanner.Shared.Models

<Breadcrumb style="--bs-breadcrumb-divider: '>';" Items="_navItems"></Breadcrumb>

<style>
    .grid-additional-columns th:nth-child(1),
    .grid-additional-columns td:nth-child(1) {
        width: 40px;
        max-width: 40px;
    }

    .grid-additional-columns th:nth-child(3),
    .grid-additional-columns td:nth-child(3) {
        width: 60px;
        max-width: 60px;
    }

    .grid-additional-columns th:nth-child(4),
    .grid-additional-columns td:nth-child(4) {
        width: 40px;
        max-width: 40px;
    }
</style>

@if (showCopiedMessage)
{
    <div class="alert alert-success position-fixed bottom-0 end-0 m-3 py-1 px-2">
        Copied to clipboard
    </div>
}

<div class="card">
    <div class="card-header">
        <table>
            <tr>
                <td style="width: 100%;">
                    <h2>Shopping lists</h2>
                </td>
                <td style="white-space: nowrap;">
                    <button class="btn btn-primary btn-sm" type="button" @onclick="() => New()">New</button>
                </td>
            </tr>
        </table>
    </div>

    <div class="card-body">
        <GridTemplate TItem="ShoppingListModel" @ref="_shoppingListsGrid" DataProvider="DataProviderAsync" TableGridClass="@_tableGridClass">
            <Columns>
                <GridColumn TItem="ShoppingListModel" HeaderText="#" PropertyName="Index" Filterable="false" Sortable="false">
                    @context.Index
                </GridColumn>
                <GridColumn TItem="ShoppingListModel" HeaderText="Name" PropertyName="Name" SortString="Name" SortKeySelector="item => item.Name" IsDefaultSortColumn="true" SortDirection="SortDirection.Ascending" StringComparison="StringComparison.OrdinalIgnoreCase">
                    <div style="cursor: pointer;" @onclick="() => Update(context)">
                        @context.Name
                    </div>
                </GridColumn>
                <GridColumn TItem="ShoppingListModel" Filterable="false">
                    <button class="btn btn-primary btn-sm" type="button" @onclick="() => Export(context)">Export</button>
                </GridColumn>
                <GridColumn TItem="ShoppingListModel" Filterable="false">
                    <button class="btn-close btn-sm" type="button" @onclick="() => DeleteAsync(context)"></button>
                </GridColumn>
            </Columns>
        </GridTemplate>
    </div>
</div>

<ConfirmDialog @ref="_dialog" />