@page "/contactus"

<style>
    .contact-background {
        background-image: url('images/loginbackground.jpg');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 800px;
        text-align: center;
    }

    .contact-form {
        background: rgba(255, 255, 255, 0.85);
        padding: 2rem;
        border-radius: 8px;
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
        text-align: left;
        width: 480px;
        margin: 3rem auto;
    }
</style>

<div class="contact-background">
    <EditForm Model="Model" OnValidSubmit="OnSubmitAsync" class="contact-form">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <h4 class="mb-3">@Resources.ContactUs.PageTitle</h4>

        <div class="form-group mb-2">
            <label for="name">@Resources.ContactUs.NameLabel</label>
            <InputText id="name" class="form-control" @bind-Value="Model.Name" placeholder="@Resources.ContactUs.PlaceholderName" />
            <ValidationMessage For="@(() => Model.Name)" />
        </div>

        <div class="form-group mb-2">
            <label for="email">@Resources.ContactUs.EmailLabel</label>
            <InputText id="email" class="form-control" @bind-Value="Model.EmailAddress" placeholder="@Resources.ContactUs.PlaceholderEmail" />
            <ValidationMessage For="@(() => Model.EmailAddress)" />
        </div>

        <div class="form-group mb-2">
            <label for="subject">@Resources.ContactUs.SubjectLabel</label>
            <InputText id="subject" class="form-control" @bind-Value="Model.Subject" placeholder="@Resources.ContactUs.PlaceholderSubject" />
            <ValidationMessage For="@(() => Model.Subject)" />
        </div>

        <div class="form-group mb-2">
            <label for="message">@Resources.ContactUs.MessageLabel</label>
            <InputTextArea id="message" class="form-control" rows="5" @bind-Value="Model.Message" placeholder="@Resources.ContactUs.PlaceholderMessage" />
            <ValidationMessage For="@(() => Model.Message)" />
        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-primary btn-sm" disabled="@_isSending">@Resources.ContactUs.SubmitButton</button>
        </div>
    </EditForm>
</div>
