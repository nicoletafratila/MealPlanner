@using MealPlanner.UI.Web.Pages.Identities
@using MudBlazor
@using MealPlanner.UI.Web.Shared

@inherits LayoutComponentBase

<style>
    .login-cell,
    .contact-cell,
    .about-cell {
        width: 1%;
        white-space: nowrap;
        padding: 0;
        text-align: end;
        vertical-align: middle;
        align-content: flex-end;
    }

        .contact-cell a,
        .about-cell a {
            display: inline-block;
            padding-left: 0.5em;
        }

    .motto-text {
        font-size: 1.1rem;
        font-weight: 500;
        text-align: left;
        width: 230px;
    }

    .current-menu-cell {
        text-align: center;
        vertical-align: bottom;
        white-space: nowrap;
    }

    .current-menu-link {
        font-size: 0.95rem;
        font-weight: 500;
        margin: 0;
    }
</style>

<PageTitle>@Resources.MainLayout.PageTitle</PageTitle>

<MudContainer Class="page-container">
    <MudPaper Class="banner">
        <Banner />
    </MudPaper>

    <div class="banner-container">
        <table>
            <tr>
                <td class="image-column">
                    <img src="Images\logo.jpg" alt="Logo Image" class="logo-image" />
                </td>
                <td style="width: 375px;">
                    <p class="logo-text">@Resources.MainLayout.LogoText</p>
                </td>
                <td>
                </td>
                <td>
                </td>
                <td>
                </td>
                <td>
                </td>
            </tr>
            <tr>
                <td colspan="2">
                    <p class="motto-text" style="width: 475px;">@Resources.MainLayout.Motto</p>
                </td>
                <td class="current-menu-cell">
                    @if (_currentMealPlan is not null)
                    {
                        <p class="current-menu-link">
                            @Resources.MainLayout.CurrentMenuLabel <a href="mealplans/mealplanedit/@_currentMealPlan.Id">@_currentMealPlan.Name</a>
                        </p>
                    }
                    else if (_isAuthenticated)
                    {
                        <p class="current-menu-link">
                            @Resources.MainLayout.NoMenuYetPrefix<a href="mealplans/mealplanedit/">@Resources.MainLayout.NoMenuYetLinkText</a>@Resources.MainLayout.NoMenuYetSuffix
                        </p>
                    }
                </td>
                <td class="login-cell">
                    <LoginDisplay />
                </td>
                <td class="contact-cell">
                    <a href="contactus/">@Resources.MainLayout.ContactUs</a>
                </td>
                <td class="about-cell">
                    <a href="https://linkedin.com/in/claudia-nicoleta-fratila" target="_blank">@Resources.MainLayout.AboutMe</a>
                </td>
            </tr>
        </table>
        <hr class="custom-line">
    </div>

    <table style="width: 100%; height: 100%;">
        <tr>
            <td class="row">
                <NavMenu />
            </td>
            <td style="vertical-align: top; width: 100%; height: 100%; padding-right: 150px;">
                <div>
                    <main>
                        <div class="content">
                            @if (IsErrorActive)
                            {
                                <div>
                                    <Alert Color="AlertColor.Danger" Dismissable="true" OnClose="HideErrorAsync">
                                        <Icon Name="IconName.ExclamationTriangleFill" class="me-2"></Icon>
                                        @Message
                                    </Alert>
                                </div>
                            }
                            @if (IsInfoActive)
                            {
                                <div>
                                    <Alert Color="AlertColor.Success" Dismissable="true" OnClose="HideInfoAsync">
                                        <Icon Name="IconName.CheckCircleFill" class="me-2"></Icon>
                                        @Message
                                    </Alert>
                                </div>
                            }
                            <CascadingValue Value="(Func<Task>)RefreshCurrentMealPlanAsync" Name="RefreshCurrentMealPlan">
                                <CascadingValue Value="this" Name="MessageComponent">
                                    <div>
                                        <div>
                                            @Body
                                        </div>
                                    </div>
                                </CascadingValue>
                            </CascadingValue>
                        </div>
                    </main>
                </div>
            </td>
        </tr>
    </table>
</MudContainer>

<Modal IsServiceModal="true" />
<Preload />
<Toasts class="p-3" AutoHide="true" Delay="4000" Placement="ToastsPlacement.TopRight" />
