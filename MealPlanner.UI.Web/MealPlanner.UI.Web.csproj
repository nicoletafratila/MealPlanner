    </Content>
  </ItemGroup>

  <!-- After dotnet clean, BuildBundlerMinifier deletes site.min.css but DefineStaticWebAssets
       runs before the bundler regenerates it. Copy site.css as a fallback so the asset exists. -->
  <Target Name="EnsureMinCssExists" BeforeTargets="DefineStaticWebAssets">
    <Copy SourceFiles="wwwroot\css\site.css" DestinationFiles="wwwroot\css\site.min.css" Condition="!Exists('$(MSBuildProjectDirectory)\wwwroot\css\site.min.css')" />
  </Target>

